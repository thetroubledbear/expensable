# Database — use the DIRECT (non-pooled) connection for Payload migrations
DATABASE_URL_UNPOOLED=postgresql://USER:PASS@HOST/DB
DIRECT_URL=postgresql://USER:PASS@HOST/DB

# Payload CMS secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=change-me-in-production

# Google Cloud Storage (same bucket as apps/web)
GCS_BUCKET=expensable
GCS_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# App subdomain — used for auth links on landing pages
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Self-referencing URL (used internally for notices API)
LANDING_URL=http://localhost:3001
