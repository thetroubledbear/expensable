# Database (Neon)
# DATABASE_URL = pooled connection (pgbouncer) — used at runtime
# DIRECT_URL   = direct connection — used by Prisma migrations only
DATABASE_URL="postgresql://user:pass@ep-xxx.pooler.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI — Google Gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Storage (Google Cloud Storage)
# GCS_SERVICE_ACCOUNT_KEY = full service account JSON as a single-line string (for Vercel)
# Leave empty locally if using: gcloud auth application-default login
GCS_BUCKET="expensable"
GCS_SERVICE_ACCOUNT_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRO_PRICE_ID=""
STRIPE_FAMILY_PRICE_ID=""

# Payload CMS
PAYLOAD_SECRET=your-secret-here-min-32-chars
