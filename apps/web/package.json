{
  "name": "@expensable/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && npm run copy-prisma-engine && next build",
    "copy-prisma-engine": "node -e \"const {cpSync,mkdirSync}=require('fs');mkdirSync('./generated/client',{recursive:true});cpSync('../../packages/db/generated/client','./generated/client',{recursive:true});\"",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:generate": "cd ../../packages/db && npx prisma generate",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@expensable/api-client": "*",
    "@expensable/db": "*",
    "@expensable/types": "*",
    "@expensable/utils": "*",
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.0",
    "@stripe/stripe-js": "^9.2.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.8.1",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^1.3.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
