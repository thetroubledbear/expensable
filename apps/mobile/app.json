{
  "expo": {
    "name": "Expensable",
    "slug": "expensable",
    "scheme": "expensable",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": false,
    "android": {
      "package": "com.expensable.app",
      "adaptiveIcon": {
        "backgroundColor": "#059669"
      }
    },
    "ios": {
      "bundleIdentifier": "com.expensable.app",
      "supportsTablet": true
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/7ec4980c-e686-4da6-b9f5-d01425cd0f1f"
    },
    "extra": {
      "eas": {
        "projectId": "7ec4980c-e686-4da6-b9f5-d01425cd0f1f"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      ["expo-speech-recognition", {
        "microphonePermission": "Allow Expensable to use the microphone for voice input.",
        "speechRecognitionPermission": "Allow Expensable to recognize your speech to log transactions.",
        "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
      }]
    ]
  }
}
